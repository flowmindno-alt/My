<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <title>Location Scanner PRO</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Arial;
      text-align: center;
      padding: 20px;
      background: #f5f5f5;
    }

    button {
      padding: 15px 25px;
      font-size: 18px;
      cursor: pointer;
      border: none;
      border-radius: 8px;
      background: #007bff;
      color: white;
    }

    #map {
      width: 100%;
      height: 300px;
      margin-top: 20px;
      display: none;
      border-radius: 10px;
      overflow: hidden;
    }

    #resultBox {
      margin-top: 20px;
      padding: 15px;
      background: white;
      border-radius: 10px;
      display: none;
    }

    #history {
      margin-top: 20px;
      text-align: left;
    }

    .item {
      background: white;
      padding: 10px;
      margin: 5px 0;
      border-radius: 8px;
    }
  </style>
</head>
<body>

<h1>📍 Location Scanner PRO</h1>

<button onclick="scanLocation()">Scan My Location</button>

<div id="map"></div>

<div id="resultBox">
  <h3>Rezultati</h3>
  <p id="coords"></p>
  <p id="irishGrid"></p>
  <p id="altitude"></p>
</div>

<h3>📜 Povijest</h3>
<div id="history"></div>

<script>
function scanLocation() {
  navigator.geolocation.getCurrentPosition(success, error);
}

function success(position) {
  const lat = position.coords.latitude;
  const lon = position.coords.longitude;
  const altitude = position.coords.altitude || "N/A";

  const grid = convertToIrishGrid(lat, lon);

  document.getElementById("coords").innerText =
    `Lat: ${lat}, Lon: ${lon}`;

  document.getElementById("irishGrid").innerText =
    `Irish Grid: X ${grid.x}, Y ${grid.y}`;

  document.getElementById("altitude").innerText =
    `Altitude: ${altitude} m`;

  document.getElementById("resultBox").style.display = "block";

  showMap(lat, lon);

  saveLocation(lat, lon, grid, altitude);
  loadHistory();
}

function error() {
  alert("Location error");
}

// MAP + marker
function showMap(lat, lon) {
  const mapDiv = document.getElementById("map");
  mapDiv.style.display = "block";

  mapDiv.innerHTML = `
    <iframe
      width="100%"
      height="100%"
      frameborder="0"
      src="https://maps.google.com/maps?q=${lat},${lon}&z=15&output=embed">
    </iframe>
  `;
}

// TOČNIJA Irish Grid konverzija
function convertToIrishGrid(lat, lon) {
  const a = 6377340.189;
  const b = 6356034.447;
  const F0 = 1.000035;
  const lat0 = 53.5 * Math.PI/180;
  const lon0 = -8 * Math.PI/180;
  const N0 = 250000;
  const E0 = 200000;
  const e2 = 1 - (b*b)/(a*a);

  const latRad = lat * Math.PI/180;
  const lonRad = lon * Math.PI/180;

  const nu = a * F0 / Math.sqrt(1 - e2 * Math.sin(latRad)**2);
  const p = lonRad - lon0;

  const E = E0 + nu * Math.cos(latRad) * p;
  const N = N0 + nu * (latRad - lat0);

  return {
    x: Math.round(E),
    y: Math.round(N)
  };
}

// SAVE
function saveLocation(lat, lon, grid, altitude) {
  let data = JSON.parse(localStorage.getItem("locations")) || [];

  data.push({
    lat, lon,
    x: grid.x,
    y: grid.y,
    altitude
  });

  localStorage.setItem("locations", JSON.stringify(data));
}

// LOAD HISTORY
function loadHistory() {
  let data = JSON.parse(localStorage.getItem("locations")) || [];
  let historyDiv = document.getElementById("history");

  historyDiv.innerHTML = "";

  data.slice().reverse().forEach(loc => {
    historyDiv.innerHTML += `
      <div class="item">
        📍 ${loc.lat.toFixed(4)}, ${loc.lon.toFixed(4)}<br>
        Grid: ${loc.x}, ${loc.y}<br>
        Alt: ${loc.altitude}
      </div>
    `;
  });
}

loadHistory();
</script>

</body>
</html>
